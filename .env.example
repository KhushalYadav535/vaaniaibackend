# VaaniAI Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── Server Configuration ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
BACKEND_URL=http://localhost:5000

# ─── Database ───────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/vaaniai
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/vaaniai

# ─── Authentication ─────────────────────────────────────────────────────────
JWT_SECRET=vaaniai_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRES_IN=7d

# ─── LLM Services (Groq) ────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
# Get free API key at: https://console.groq.com

# ─── Speech-to-Text (Deepgram) ──────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here
# Get $200 free credits at: https://deepgram.com

# ─── Text-to-Speech (ElevenLabs - Optional) ────────────────────────────────
ELEVENLABS_API_KEY=
# Optional: Get API key at https://elevenlabs.io

# ─── Telephony (Twilio) ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
RECORD_CALLS=true
# Get free trial at: https://twilio.com

# ─── AWS S3 (For Recording Storage) ────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your-bucket-name
# Optional: Set up S3 for storing call recordings and transcripts

# ─── Redis (Optional - For Rate Limiting) ──────────────────────────────────
REDIS_URL=redis://localhost:6379
# Optional: Use Redis for distributed rate limiting

# ─── Frontend & CORS ────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# ─── Campaign Worker Configuration ─────────────────────────────────────────
MAX_CONCURRENT_CALLS=5
DELAY_BETWEEN_CALLS=2000

# ─── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=1000
VOICE_CALL_LIMIT_PER_HOUR=50
CAMPAIGN_LIMIT_PER_HOUR=5

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Values: error, warn, info, debug

# ─── WebSocket ──────────────────────────────────────────────────────────────
WS_PORT=5001
WS_HEARTBEAT_INTERVAL=30000

