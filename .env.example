# VaaniAI Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── Server Configuration ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
BACKEND_URL=http://localhost:5000

# ─── Database ───────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/vaaniai
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/vaaniai

# ─── Authentication ─────────────────────────────────────────────────────────
JWT_SECRET=vaaniai_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRES_IN=7d
SUPER_ADMIN_WRITE_ENABLED=false

# ─── LLM Services (Groq) ────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
# Get free API key at: https://console.groq.com
GROQ_TIMEOUT_MS=8000
GROQ_CIRCUIT_FAILURE_THRESHOLD=5
GROQ_CIRCUIT_RESET_MS=20000
GROQ_FALLBACK_MODELS=llama-3.3-70b-versatile,mixtral-8x7b-32768
FAST_FIRST_CHUNK_MODE=true
FAST_FIRST_CHUNK_CHAR_THRESHOLD=36
FAST_FIRST_CHUNK_MAX_WORDS=8

# ─── Speech-to-Text (Deepgram) ──────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here
# Get $200 free credits at: https://deepgram.com
FAST_TURN_MODE=false
DEEPGRAM_UTTERANCE_END_MS=1200
DEEPGRAM_ENDPOINTING_MS=400
MIN_TRANSCRIPT_CHARS_FOR_FINAL=2
STT_FALLBACK_LANGUAGE=multi
DEEPGRAM_MODEL=nova-3
DEEPGRAM_FORCE_MULTI=true
DEEPGRAM_HINDI_FALLBACK=multi
DEEPGRAM_AUDIO_INPUT_MODE=raw
DEEPGRAM_MIME_TYPE=audio/webm;codecs=opus
# Raw mode only (when DEEPGRAM_AUDIO_INPUT_MODE=raw)
DEEPGRAM_ENCODING=opus
DEEPGRAM_SAMPLE_RATE=48000
DEEPGRAM_CHANNELS=1
# FAST_TURN_MODE=true suggested start:
# DEEPGRAM_UTTERANCE_END_MS=650
# DEEPGRAM_ENDPOINTING_MS=250
MAX_AUDIO_CHUNK_BYTES=262144
MAX_AUDIO_BYTES_PER_SECOND=524288
WS_MAX_BUFFERED_BYTES=2097152

# ─── Text-to-Speech (ElevenLabs - Optional) ────────────────────────────────
ELEVENLABS_API_KEY=
# Optional: Get API key at https://elevenlabs.io

# ─── Telephony (Twilio) ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
RECORD_CALLS=true
# Get free trial at: https://twilio.com

# ─── AWS S3 (For Recording Storage) ────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your-bucket-name
# Optional: Set up S3 for storing call recordings and transcripts

# ─── Redis (Optional - For Rate Limiting) ──────────────────────────────────
REDIS_URL=redis://localhost:6379
# Optional: Use Redis for distributed rate limiting

# ─── Frontend & CORS ────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# ─── Campaign Worker Configuration ─────────────────────────────────────────
MAX_CONCURRENT_CALLS=5
DELAY_BETWEEN_CALLS=2000
CALL_LOG_FLUSH_TIMEOUT_MS=1500

# ─── RAG Performance ────────────────────────────────────────────────────────
RAG_MIN_QUERY_CHARS=12
RAG_TOP_K=3
RAG_DISABLE_RERANK=false
RAG_MIN_WORDS_FOR_RERANK=4
RAG_CONTEXT_CACHE_TTL_MS=15000

# ─── Eval / Load Test Harness ───────────────────────────────────────────────
EVAL_WS_URL=ws://localhost:5000/ws/voice
EVAL_TOKEN=
EVAL_AGENT_ID=
EVAL_MAX_STT_TO_FIRST_AUDIO_MS=2000
EVAL_SCENARIO_TIMEOUT_MS=15000
EVAL_OUTPUT_JSON=true
LOAD_CONCURRENCY=10
LOAD_TIMEOUT_MS=25000

# ─── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=1000
VOICE_CALL_LIMIT_PER_HOUR=50
CAMPAIGN_LIMIT_PER_HOUR=5

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Values: error, warn, info, debug

# ─── WebSocket ──────────────────────────────────────────────────────────────
WS_PORT=5001
WS_HEARTBEAT_INTERVAL=30000

